# Copy to .env and adjust per environment (dev / staging / prod).
# Restart Expo after changes: npx expo start --clear

# ── API ───────────────────────────────────────────────────────
EXPO_PUBLIC_API_BASE_URL=https://neatly-twisted-agile.ngrok-free.dev
# EXPO_PUBLIC_API_TIMEOUT_MS=15000

# ── Firebase (phone OTP) ──────────────────────────────────────
# Or paste into FIREBASE_DEV_CONFIG in src/config/auth.js
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ── Social login ──────────────────────────────────────────────
# Web application OAuth client (NOT Android client) — required for Expo Go
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=807444567658-l9gq0ophos92739p6o9vjms7kmq0407o.apps.googleusercontent.com
EXPO_PUBLIC_FACEBOOK_APP_ID=999372849281178
